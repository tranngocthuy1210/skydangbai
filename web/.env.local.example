# Backend NestJS. Đổi nếu API chạy ở cổng/domain khác.
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Auth hiện là stub ở backend (header x-user-id).
# Bỏ trống → backend tự dùng user demo đầu tiên trong DB.
# Muốn cố định 1 user: dán UUID mà `npm run seed` in ra.
NEXT_PUBLIC_DEMO_USER_ID=

# ===== CHẾ ĐỘ DEMO =====
# =1 → frontend KHÔNG gọi API, dùng dữ liệu mẫu trong lib/demo-data.ts và
#      hiện nhãn "Bản demo giao diện" trên mọi trang.
#
# Dùng khi deploy chỉ-frontend lên Vercel (không có backend). Nếu để trống
# trong trường hợp đó, người xem sẽ thấy lỗi "không kết nối được localhost:3000"
# vì trình duyệt của họ đi tìm localhost của CHÍNH MÁY HỌ.
#
# ĐẶT LẠI VỀ RỖNG ngay khi đã có backend thật.
NEXT_PUBLIC_DEMO_MODE=
